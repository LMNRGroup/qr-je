# Environment variables for the Next.js app (frontend-next).
# Copy to `.env.local` and fill in real values:  cp .env.example .env.local
#
# New deployments should use these NEXT_PUBLIC_* names. The legacy VITE_*
# names are still accepted as fallbacks during the migration (see next.config.mjs).

# ── Required ────────────────────────────────────────────────────────────────
# A production build fails fast if these are missing (next.config.mjs validates).

# Supabase project URL.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Supabase public key. Provide ONE of the two below.
# Prefer the publishable key; the anon key is the older equivalent.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# ── Optional (have sensible defaults) ─────────────────────────────────────────

# Backend API origin used by the client. Defaults to https://api.luminarapps.com
# (http://localhost:3000 in development).
# NEXT_PUBLIC_API_BASE_URL=http://localhost:3000

# Public site URL, used for canonical/OpenGraph metadata.
# Defaults to https://qrcode.luminarapps.com
# NEXT_PUBLIC_APP_URL=http://localhost:8081

# Feature flag: set to "true" to opt into the v2 mobile UI. Defaults to off.
# NEXT_PUBLIC_MOBILE_UI_V2=false

# ── Server-only (not exposed to the browser) ──────────────────────────────────

# Origin that Next rewrites proxy to (/r, /adaptive, /public, public vCard pages).
# Defaults to NEXT_PUBLIC_API_BASE_URL, then https://api.luminarapps.com.
# API_PROXY_ORIGIN=http://localhost:3000

# Dev-only: set to "true" to proxy public vCard/menu pages to the backend HTML
# renderer instead of rendering the React route locally. Always on in production.
# PROXY_PUBLIC_PAGES=false
