{
  "rewrites": [
    {
      "source": "/r/:id/:random",
      "destination": "https://api.luminarapps.com/r/:id/:random"
    },
    {
      "source": "/adaptive/:id/:random",
      "destination": "https://api.luminarapps.com/adaptive/:id/:random"
    },
    {
      "source": "/public/:path*",
      "destination": "https://api.luminarapps.com/public/:path*"
    },
    {
      "source": "/:owner((?!v$|menu$|file$|r$|adaptive$|public$|assets$|login$|forgot-password$|reset-password$|terms$|privacy$|support$|data-deletion$|faq$)[^/]+)/:slug",
      "destination": "https://api.luminarapps.com/public/pages/:owner/:slug"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
